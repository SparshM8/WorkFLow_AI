# MeetFlow AI — Environment Variables
#
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# Add .env to .gitignore immediately.
#
# All VITE_ prefixed variables are exposed to the browser bundle.
# Firebase API keys are NOT secret (they are public project identifiers).
# Actual security comes from Firestore Security Rules (see firestore.rules).
# Your Gemini API key IS sensitive — restrict it in Google Cloud Console.

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
# Restrict to: Generative Language API only in Google Cloud Console
VITE_GEMINI_KEY=your-gemini-api-key-here

# ── Firebase ──────────────────────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY=your-firebase-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
